# ============================================================
#  FSES Monorepo — .gitignore
#  Covers: client/ (Vite + React)  |  server/ (Express – TBD)
# ============================================================


# ─── Dependencies ───────────────────────────────────────────
node_modules/
.pnp
.pnp.js
.yarn/install-state.gz


# ─── Build Outputs ──────────────────────────────────────────
dist/
build/
out/
.output/


# ─── Environment & Secrets ──────────────────────────────────
.env
.env.local
.env.development
.env.development.local
.env.test
.env.test.local
.env.production
.env.production.local
.env.staging


# ─── Logs ───────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*


# ─── Vite (client/) ─────────────────────────────────────────
client/.vite/
client/dist/
client/dist-ssr/
*.local


# ─── Express / Node (server/) ───────────────────────────────
server/dist/
server/build/
uploads/          # local file uploads (use cloud storage in prod)
*.pid
*.seed
*.pid.lock


# ─── Testing ────────────────────────────────────────────────
coverage/
.nyc_output/
*.lcov


# ─── OS & Editor ────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
Desktop.ini

.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/launch.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?


# ─── TypeScript ─────────────────────────────────────────────
*.tsbuildinfo


# ─── Misc ───────────────────────────────────────────────────
.cache/
.parcel-cache/
tmp/
temp/
